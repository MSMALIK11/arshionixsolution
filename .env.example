# Site URL (used in sitemap, robots, metadata)
NEXT_PUBLIC_SITE_URL=https://arshionix.com

# Contact form: Resend (https://resend.com). Without this, form submissions are logged to server only.
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=info@arshionix.com

# Optional: Book a call link (e.g. Calendly). If set, "Book a free call" appears in Contact section.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link

# Social links (replace with your profiles)
NEXT_PUBLIC_GITHUB_URL=https://github.com/your-org
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/your-company
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/your-handle
